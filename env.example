# Site and Agent Identification
SITE_ID=default-site
AGENT_ID=default-agent

# External Service URLs
UTILITY_URL=http://localhost:8001
WEATHER_MCP_URL=http://localhost:8002

# Authentication
API_KEY_SOLAR=your-solar-api-key-here
LLM_API_KEY=your-openai-api-key-here

# Operational Parameters
FORECAST_INTERVAL=300
ANOMALY_THRESHOLD=0.15
READING_HISTORY_SIZE=100

# Adapter Configuration
ADAPTER_TYPE=simulated
FAILURE_RATE=0.0
FAILURE_DURATION=60
BASE_POWER_KW=5.0
POWER_VARIATION=2.0

# Logging and Monitoring
LOG_LEVEL=INFO
METRICS_PORT=8000

# Development Settings
# Uncomment and modify as needed for development
# DEBUG=true
# TESTING=true 